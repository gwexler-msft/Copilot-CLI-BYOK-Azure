<policies>
  <inbound>
    <base />

    <!-- 1. Copilot CLI BYOK 'azure' mode sends our JWT as the 'api-key' header.
         We pull it into a variable so the rest of the policy is explicit. -->
    <set-variable name="incomingApiKey" value="@(context.Request.Headers.GetValueOrDefault("api-key",""))" />

    <choose>
      <when condition="@(string.IsNullOrEmpty((string)context.Variables["incomingApiKey"]))">
        <return-response>
          <set-status code="401" reason="Missing api-key header (expected Entra JWT)" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"error":"Missing api-key header. Set COPILOT_PROVIDER_API_KEY to an Entra JWT minted via 'az account get-access-token --resource {{api-app-id-uri}}'."}</set-body>
        </return-response>
      </when>
    </choose>

    <!-- 2. Re-inject the JWT as an Authorization Bearer header so validate-jwt can read it. -->
    <set-header name="Authorization" exists-action="override">
      <value>@("Bearer " + (string)context.Variables["incomingApiKey"])</value>
    </set-header>

    <!-- 3. Validate the JWT against Entra OIDC metadata. Audience and scope must match. -->
    <validate-jwt header-name="Authorization"
                  failed-validation-httpcode="401"
                  failed-validation-error-message="Unauthorized: invalid Entra token."
                  require-scheme="Bearer"
                  require-signed-tokens="true"
                  output-token-variable-name="parsedJwt">
      <openid-config url="{{entra-openid-config-url}}" />
      <audiences>
        <!-- v2 access tokens carry aud = the app (client) ID GUID, not the api:// URI. -->
        <audience>{{api-audience}}</audience>
      </audiences>
      <required-claims>
        <claim name="scp" match="any">
          <value>{{required-scope}}</value>
        </claim>
      </required-claims>
    </validate-jwt>

    <!-- 4. Extract developer identity + requested model for telemetry. Copilot CLI uses the
         OpenAI-style /v1/* surface: the model/deployment name is in the request BODY. -->
    <set-variable name="developerOid" value="@(((Jwt)context.Variables["parsedJwt"]).Claims.GetValueOrDefault("oid", "unknown"))" />
    <set-variable name="developerUpn" value="@(((Jwt)context.Variables["parsedJwt"]).Claims.GetValueOrDefault("preferred_username", ((Jwt)context.Variables["parsedJwt"]).Claims.GetValueOrDefault("upn", "unknown")))" />
    <set-variable name="deploymentName" value="@{
        try {
            var body = context.Request.Body?.As<JObject>(preserveContent: true);
            return (string)(body?["model"]?.ToString()) ?? "unknown";
        } catch { return "unknown"; }
    }" />

    <!-- 4a. Guard: fail fast with 400 if we could not read a model name from the body. -->
    <choose>
      <when condition="@(string.IsNullOrEmpty((string)context.Variables["deploymentName"]) || (string)context.Variables["deploymentName"] == "unknown")">
        <return-response>
          <set-status code="400" reason="Could not determine model from request body" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"error":{"code":"ModelNotSpecified","message":"Could not parse a 'model' field from the JSON request body. Ensure the body is valid JSON, e.g. {\"model\":\"&lt;deployment&gt;\",\"messages\":[...]}. (A common cause is shell quote mangling of the JSON payload.)"}}</set-body>
        </return-response>
      </when>
    </choose>

    <!-- 4b. Backend selection. This is the DEFAULT route: traffic goes to Foundry (AIServices)
         unless the requested model is pinned to the legacy AOAI backend via the
         comma-separated {{aoai-pinned-models}} named value. -->
    <set-variable name="routeToAoai" value="@{
        var pinned = "{{aoai-pinned-models}}".Split(new[]{','}, System.StringSplitOptions.RemoveEmptyEntries);
        var model = ((string)context.Variables["deploymentName"]).Trim().ToLowerInvariant();
        foreach (var m in pinned) { if (m.Trim().ToLowerInvariant() == model) { return true; } }
        return false;
    }" />
    <set-variable name="backendName" value="@((bool)context.Variables["routeToAoai"] ? "aoai" : "foundry")" />

    <emit-metric name="copilot_byok_request" value="1" namespace="copilot.byok">
      <dimension name="developer_oid" value="@((string)context.Variables["developerOid"])" />
      <dimension name="developer_upn" value="@((string)context.Variables["developerUpn"])" />
      <dimension name="deployment_name" value="@((string)context.Variables["deploymentName"])" />
      <dimension name="backend" value="@((string)context.Variables["backendName"])" />
    </emit-metric>

    <!-- 5. Per-developer throttles (jwt mode keys on the Entra oid). Numbers come from named
         values so they are tunable per deployment without editing this policy:
           rate-limit-by-key        burst (calls/min)
           azure-openai-token-limit AI-cost guard (tokens/min, prompt+completion)
           quota-by-key             hard monthly call ceiling (30 days)
         (In subscriptionKey mode these live at PRODUCT scope instead; see apim-products.) -->
    <rate-limit-by-key calls="{{jwt-calls-per-minute}}" renewal-period="60"
                       counter-key="@((string)context.Variables["developerOid"])"
                       increment-condition="@(context.Response.StatusCode == 200)"
                       remaining-calls-header-name="x-byok-calls-remaining" />
    <azure-openai-token-limit tokens-per-minute="{{jwt-tokens-per-minute}}"
                              counter-key="@((string)context.Variables["developerOid"])"
                              estimate-prompt-tokens="true"
                              remaining-tokens-header-name="x-byok-tokens-remaining"
                              tokens-consumed-header-name="x-byok-tokens-consumed" />
    <quota-by-key calls="{{jwt-monthly-call-quota}}" renewal-period="2592000"
                  counter-key="@((string)context.Variables["developerOid"])" />

    <!-- 6. Strip the dev's credential before going to the backend. -->
    <set-header name="api-key" exists-action="delete" />
    <set-header name="Authorization" exists-action="delete" />

    <!-- 7. Determine the AOAI-style operation from the path (common to both backends). -->
    <set-variable name="aoaiOp" value="@{
        var p = context.Request.OriginalUrl.Path.ToLowerInvariant();
        if (p.EndsWith("/chat/completions")) { return "chat/completions"; }
        if (p.EndsWith("/embeddings")) { return "embeddings"; }
        return "completions";
    }" />

    <!-- 8. Mint a managed identity token for the chosen backend and route to it.
         Both surfaces share the OpenAI-compatible MI audience (cognitiveservices.azure.*),
         but keep them as separate named values so they can diverge later. -->
    <choose>
      <when condition="@((bool)context.Variables["routeToAoai"])">
        <authentication-managed-identity resource="{{aoai-mi-audience}}" />
        <set-backend-service base-url="{{aoai-private-base-url}}" />
      </when>
      <otherwise>
        <authentication-managed-identity resource="{{foundry-mi-audience}}" />
        <set-backend-service base-url="{{foundry-private-base-url}}" />
      </otherwise>
    </choose>

    <!-- 9. Rewrite the OpenAI-style /v1/<op> path to the deployment-scoped data-plane path
         the backend expects: /openai/deployments/{model}/<op>. Identical for both backends. -->
    <rewrite-uri template="@("/openai/deployments/" + (string)context.Variables["deploymentName"] + "/" + (string)context.Variables["aoaiOp"])" copy-unmatched-params="true" />

    <!-- 10. Force a known-good api-version (Copilot CLI omits/hardcodes it; see #3208). -->
    <set-query-parameter name="api-version" exists-action="override">
      <value>{{aoai-default-api-version}}</value>
    </set-query-parameter>
  </inbound>

  <backend>
    <base />
  </backend>

  <outbound>
    <base />

    <!-- Parse the 'usage' object from a JSON response and emit token metrics. -->
    <choose>
      <when condition="@(context.Response.StatusCode == 200 && (context.Response.Headers.GetValueOrDefault("Content-Type","").StartsWith("application/json")))">
        <set-variable name="responseBody" value="@(context.Response.Body.As<JObject>(preserveContent: true))" />
        <emit-metric name="copilot_byok_prompt_tokens"     value="@((double)(int)(((JObject)context.Variables["responseBody"])?["usage"]?["prompt_tokens"] ?? 0))" namespace="copilot.byok">
          <dimension name="developer_oid"   value="@((string)context.Variables["developerOid"])" />
          <dimension name="developer_upn"   value="@((string)context.Variables["developerUpn"])" />
          <dimension name="deployment_name" value="@((string)context.Variables["deploymentName"])" />
          <dimension name="backend"         value="@((string)context.Variables["backendName"])" />
        </emit-metric>
        <emit-metric name="copilot_byok_completion_tokens" value="@((double)(int)(((JObject)context.Variables["responseBody"])?["usage"]?["completion_tokens"] ?? 0))" namespace="copilot.byok">
          <dimension name="developer_oid"   value="@((string)context.Variables["developerOid"])" />
          <dimension name="developer_upn"   value="@((string)context.Variables["developerUpn"])" />
          <dimension name="deployment_name" value="@((string)context.Variables["deploymentName"])" />
          <dimension name="backend"         value="@((string)context.Variables["backendName"])" />
        </emit-metric>
      </when>
    </choose>
  </outbound>

  <on-error>
    <base />
  </on-error>
</policies>
