<!--
  ===========================================================================
  Wizard-generated GenAI policy, FIXED for the GitHub Copilot CLI (BYOK).
  ===========================================================================
  This is the policy the APIM "Import Azure OpenAI / AI Foundry" wizard
  generates, with two production fixes applied. It is intentionally kept
  CLOSE to the wizard output (same <llm-emit-token-metric> + <llm-token-limit>
  GenAI policies, same backend, same dimensions) so the client can adopt it
  with minimal change. The fuller BYOK design (JWT auth, auto model-routing,
  multi-backend failover, custom copilot.byok metrics) is phased in later via
  byok-foundry-policy.xml.

  WHAT WAS WRONG WITH THE RAW WIZARD POLICY
  -----------------------------------------
  1) NO METRICS REACHED APP INSIGHTS.
     <llm-emit-token-metric> can only emit when it can read a `usage` object
     out of the model response. Copilot CLI calls are STREAMING
     (stream:true), and streamed responses OMIT `usage` unless the caller
     sends `stream_options.include_usage = true`. Copilot CLI does not send
     it, so there was no usage to parse and nothing was emitted.
        FIX A: inject `stream_options.include_usage = true` into streaming
        request bodies (see step 2). Now every streamed response ends with a
        usage chunk, so <llm-emit-token-metric> emits reliably.
        FIX A2: also emit an always-on generic request counter
        (<emit-metric value="1">) that does NOT depend on `usage`, so request
        telemetry flows even if a caller somehow suppresses usage.

  2) FREQUENT 429s.
     The wizard set tokens-per-minute="10000" with estimate-prompt-tokens="true".
     A Copilot CLI request (system prompt + file context) is routinely
     5k-15k tokens BY ITSELF, so the pre-flight estimate alone exhausted a
     10k/min budget and 429'd on a single normal request.
        FIX B: raise tokens-per-minute to a realistic ceiling for an agentic
        coding client (see the named-value note below) and treat it as a
        cost SAFETY CEILING, not a tight throttle.

  TUNING
  ------
  - tokens-per-minute below is the per-minute SAFETY CEILING. Set it at or
    just under the deployment's provisioned TPM quota. 10000 is far too low
    for Copilot CLI; 200000 is a sane starting point - lower it only if you
    must protect a small shared deployment, and prefer protecting capacity
    with a calls/min rate-limit rather than a tight TPM.
  - token-quota / token-quota-period is the monthly cost guard (unchanged
    from the wizard: 3,000,000 tokens / month per subscription).
  - counter-key keys on the APIM subscription id (one key per developer),
    exactly as the wizard did.
  ===========================================================================
-->
<policies>
  <inbound>
    <base />
    <set-backend-service id="apim-generated-policy" backend-id="foundry-gov-copilot-pov-test-01-ai-endpoint" />

    <!-- FIX A: ensure streamed responses carry a `usage` object so the token
         metric below can actually emit. Only touches streaming JSON requests;
         leaves non-streaming bodies untouched. Safe no-op if the body already
         sets stream_options.include_usage. -->
    <set-body>@{
        try {
            var body = context.Request.Body?.As<JObject>(preserveContent: true);
            if (body == null) { return context.Request.Body?.As<string>(preserveContent: true); }
            var stream = body["stream"];
            if (stream != null && stream.Type == JTokenType.Boolean && (bool)stream) {
                var opts = body["stream_options"] as JObject;
                if (opts == null) { opts = new JObject(); body["stream_options"] = opts; }
                opts["include_usage"] = true;
            }
            return body.ToString();
        } catch {
            // If the body is not JSON we can parse, forward it unchanged.
            return context.Request.Body?.As<string>(preserveContent: true);
        }
    }</set-body>

    <!-- FIX A2: always-on request counter. Does NOT depend on `usage`, so
         request telemetry is guaranteed regardless of streaming behaviour.
         Shows up in App Insights customMetrics under namespace copilot.byok. -->
    <emit-metric name="copilot_byok_request" value="1" namespace="copilot.byok">
      <dimension name="API ID" />
      <dimension name="Subscription ID" />
      <dimension name="Product ID" />
      <dimension name="Operation ID" />
    </emit-metric>

    <!-- Wizard token metric (now reliable thanks to FIX A). Emits prompt /
         completion / total tokens parsed from the response `usage` object. -->
    <llm-emit-token-metric>
      <dimension name="API ID" />
      <dimension name="Client IP address" value="@(context.Request.IpAddress)" />
      <dimension name="Gateway ID" />
      <dimension name="Location" />
      <dimension name="Operation ID" />
      <dimension name="Product ID" />
      <dimension name="Subscription ID" />
      <dimension name="User ID" />
    </llm-emit-token-metric>

    <!-- Wizard token limit, RE-TUNED (FIX B). tokens-per-minute is now a
         realistic per-minute safety ceiling for a coding CLI instead of the
         10000 default that 429'd on a single request. token-quota keeps the
         monthly cost guard unchanged. -->
    <llm-token-limit
        tokens-per-minute="200000"
        token-quota="3000000"
        token-quota-period="Monthly"
        counter-key="@(context.Subscription.Id)"
        estimate-prompt-tokens="true"
        remaining-tokens-header-name="x-remaining-tpm-tokens"
        remaining-quota-tokens-header-name="x-remaining-monthly-tokens"
        tokens-consumed-header-name="x-consumed-tokens" />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
