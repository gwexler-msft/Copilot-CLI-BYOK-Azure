{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "Copy this file to infra/main.parameters.json and replace every <PLACEHOLDER>. The real main.parameters.json is gitignored so tenant-specific values are not committed.",
  "parameters": {
    "namePrefix":         { "value": "copilot-byok" },
    "envName":            { "value": "gov-pilot" },
    "location":           { "value": "usgovvirginia" },
    "cloudEnv":           { "value": "AzureUSGovernment" },
    "vnetCidr":           { "value": "10.60.0.0/16" },
    "apimSku":            { "value": "Developer" },
    "apimPublisherEmail": { "value": "<YOUR_PUBLISHER_EMAIL>" },
    "apimPublisherName":  { "value": "Copilot BYOK Gateway" },
    "modelName":          { "value": "gpt-5.1" },
    "modelVersion":       { "value": "2025-11-13" },
    "modelDeploymentSku": { "value": "DataZoneStandard" },
    "modelCapacity":      { "value": 50 },
    "apimExposedModelName": { "value": "gpt-5.1" },
    "deployAoai":         { "value": false },
    "deployFoundry":      { "value": true },
    "foundryModelName":   { "value": "gpt-5.1" },
    "foundryModelVersion": { "value": "2025-11-13" },
    "foundryModelDeploymentSku": { "value": "DataZoneStandard" },
    "foundryModelCapacity": { "value": 50 },
    "foundryExposedModelName": { "value": "gpt-5.1" },
    "aoaiPinnedModels":   { "value": "" },
    "deployMiniModel":    { "value": true },
    "miniModelName":      { "value": "gpt-4.1-mini" },
    "miniModelVersion":   { "value": "2025-04-14" },
    "miniModelDeploymentSku": { "value": "DataZoneStandard" },
    "miniModelCapacity":  { "value": 50 },
    "miniExposedModelName": { "value": "gpt-4.1-mini" },
    "autoRouteSentinel":  { "value": "auto" },
    "autoRouteLengthThreshold": { "value": 500 },
    "autoRouteAmbiguousBand": { "value": 200 },
    "autoRouteClassifierEnabled": { "value": false },
    "authMode":           { "value": "subscriptionKey" },
    "deployTestSubscriptions": { "value": true },
    "testSubscriptions":  { "value": [ { "name": "dev1", "product": "byok-standard" }, { "name": "dev2", "product": "byok-power" } ] },
    "productTiers":       { "value": [
      { "name": "byok-standard", "displayName": "BYOK Standard", "description": "Standard developer tier.", "callsPerMinute": 60, "tokensPerMinute": 20000, "monthlyCallQuota": 50000 },
      { "name": "byok-power", "displayName": "BYOK Power", "description": "Power developer tier.", "callsPerMinute": 120, "tokensPerMinute": 60000, "monthlyCallQuota": 200000 }
    ] },
    "jwtDefaultCallsPerMinute":  { "value": 120 },
    "jwtDefaultTokensPerMinute": { "value": 60000 },
    "jwtDefaultMonthlyCallQuota": { "value": 200000 },
    "raiPolicyName":      { "value": "Microsoft.DefaultV2" },
    "entraTenantId":      { "value": "<YOUR_TENANT_ID_GUID>" },
    "apiAppIdUri":        { "value": "api://copilot-byok-gateway-<YOUR_TENANT_SHORT>" },
    "apiAudience":        { "value": "<YOUR_APP_CLIENT_ID_GUID>" },
    "requiredScope":      { "value": "cli.invoke" },
    "deployVpnGateway":   { "value": false },
    "vpnRootCertPublicData": { "value": "REPLACE_WITH_BASE64_ROOT_CERT_PUBLIC_DATA_OR_LEAVE_EMPTY_IF_NOT_DEPLOYING_VPN" },
    "peerVnetResourceId": { "value": "" },
    "deployerPrincipalId": { "value": "" },
    "assignAoaiRbac":     { "value": false },
    "playgroundPrincipalIds": { "value": [] },
    "playgroundPrincipalType": { "value": "User" },
    "deployTestVm":       { "value": true },
    "deployNatGateway":   { "value": true },
    "restrictVmEgress":   { "value": true },
    "testVmAdminUsername": { "value": "byokadmin" },
    "deployApimPrivateDns": { "value": true },
    "_comment_backendPool": "Opt-in multi-region backend pools. Leave deployBackendPool=false for a single transparent Url backend (current behavior). To add regions: set deployBackendPool=true and copy the regions from _example_foundryRegions below into foundryRegions (the SAME model + mini deployment is created in each region). Turning the pool ON automatically deploys the RBAC module and grants the APIM managed identity 'Cognitive Services OpenAI User' on the primary AND every regional account (no manual grant needed). backendPoolStrategy: 'priority' = active/passive failover (primary serves all, others take over on circuit-breaker trip); 'weighted' = active/active load balancing across all regions. The policies also <retry> a transient 429/5xx onto the next healthy member within the same request. See monitoring/kql/requests-per-backend-region.kql to verify the live regional split (the App Insights 'Region' property shows the GATEWAY region, not the backend).",
    "deployBackendPool":  { "value": false },
    "backendPoolStrategy": { "value": "priority" },
    "_comment_foundryRegions": "To enable, set foundryRegions to the value shown in _example_foundryRegions (or your own list of extra regions). Each entry adds a Foundry account in that region as a pool member. location MUST be a region that hosts your foundryModelName + SKU.",
    "_example_foundryRegions": "[ { \"location\": \"usgovarizona\", \"modelCapacity\": 50, \"miniModelCapacity\": 50 } ]",
    "foundryRegions":     { "value": [] },
    "_example_aoaiRegions": "[ { \"location\": \"usgovarizona\", \"modelCapacity\": 50 } ]",
    "aoaiRegions":        { "value": [] },
    "enableBackendCircuitBreaker": { "value": true },
    "breakerFailureCount": { "value": 5 },
    "breakerInterval":    { "value": "PT1M" },
    "breakerTripDuration": { "value": "PT1M" }
  }
}
