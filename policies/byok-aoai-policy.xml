<policies>
  <inbound>
    <base />

    <!-- 1. Copilot CLI BYOK 'azure' mode sends our JWT as the 'api-key' header.
         We pull it into a variable so the rest of the policy is explicit. -->
    <set-variable name="incomingApiKey" value="@(context.Request.Headers.GetValueOrDefault("api-key",""))" />

    <choose>
      <when condition="@(string.IsNullOrEmpty((string)context.Variables["incomingApiKey"]))">
        <return-response>
          <set-status code="401" reason="Missing api-key header (expected Entra JWT)" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"error":"Missing api-key header. Set COPILOT_PROVIDER_API_KEY to an Entra JWT minted via 'az account get-access-token --resource {{api-app-id-uri}}'."}</set-body>
        </return-response>
      </when>
    </choose>

    <!-- 2. Re-inject the JWT as an Authorization Bearer header so validate-jwt can read it
         (validate-jwt's header-name="api-key" works in newer APIM, but Bearer is universal). -->
    <set-header name="Authorization" exists-action="override">
      <value>@("Bearer " + (string)context.Variables["incomingApiKey"])</value>
    </set-header>

    <!-- 3. Validate the JWT against Entra OIDC metadata. Audience and scope must match. -->
    <validate-jwt header-name="Authorization"
                  failed-validation-httpcode="401"
                  failed-validation-error-message="Unauthorized: invalid Entra token."
                  require-scheme="Bearer"
                  require-signed-tokens="true"
                  output-token-variable-name="parsedJwt">
      <openid-config url="{{entra-openid-config-url}}" />
      <audiences>
        <!-- v2 access tokens carry aud = the app (client) ID GUID, not the api:// URI. -->
        <audience>{{api-audience}}</audience>
      </audiences>
      <required-claims>
        <claim name="scp" match="any">
          <value>{{required-scope}}</value>
        </claim>
      </required-claims>
    </validate-jwt>

    <!-- 4. Extract developer identity + requested model for telemetry.
         Copilot CLI uses the OpenAI-style /openai/v1/* surface: the model/deployment
         name is carried in the request BODY ("model": "..."), not in the URL. -->
    <set-variable name="developerOid" value="@(((Jwt)context.Variables["parsedJwt"]).Claims.GetValueOrDefault("oid", "unknown"))" />
    <set-variable name="developerUpn" value="@(((Jwt)context.Variables["parsedJwt"]).Claims.GetValueOrDefault("preferred_username", ((Jwt)context.Variables["parsedJwt"]).Claims.GetValueOrDefault("upn", "unknown")))" />
    <set-variable name="deploymentName" value="@{
        try {
            var body = context.Request.Body?.As<JObject>(preserveContent: true);
            return (string)(body?["model"]?.ToString()) ?? "unknown";
        } catch { return "unknown"; }
    }" />

    <!-- 4a. Guard: if we could not read a model/deployment name from the body, fail fast
         with a clear 400 instead of forwarding to /openai/deployments/unknown/... which
         AOAI would reject with a confusing "DeploymentNotFound". Usually caused by an
         invalid-JSON body (shell quote mangling). -->
    <choose>
      <when condition="@(string.IsNullOrEmpty((string)context.Variables["deploymentName"]) || (string)context.Variables["deploymentName"] == "unknown")">
        <return-response>
          <set-status code="400" reason="Could not determine model from request body" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"error":{"code":"ModelNotSpecified","message":"Could not parse a 'model' field from the JSON request body. Ensure the body is valid JSON, e.g. {\"model\":\"&lt;deployment&gt;\",\"messages\":[...]}. (A common cause is shell quote mangling of the JSON payload.)"}}</set-body>
        </return-response>
      </when>
    </choose>

    <!-- 4a2. TIERED AUTO MODEL-ROUTING (legacy AOAI backend). When the caller sends the sentinel
         model ({{auto-route-sentinel}}, default "auto") we pick a deployment: the cheap "mini"
         tier for short, non-coding prompts and the full model otherwise. Level 1 = in-policy
         heuristic (length + coding-signal scan); Level 2 = OPTIONAL classifier-model call (off
         unless {{auto-route-classifier-enabled}} is "true") for the ambiguous band only. Resolved
         name overwrites deploymentName so metrics + rewrite see the actual model. Both tiers must
         be deployed on the AOAI account. -->
    <set-variable name="autoDecision" value="none" />
    <set-variable name="isAutoRoute" value="@(((string)context.Variables["deploymentName"]).Trim().ToLowerInvariant() == "{{auto-route-sentinel}}")" />
    <choose>
      <when condition="@((bool)context.Variables["isAutoRoute"])">
        <set-variable name="autoPromptText" value="@{
            try {
                var body = context.Request.Body?.As<JObject>(preserveContent: true);
                var msgs = body?["messages"] as JArray;
                if (msgs == null) { return ""; }
                var sb = new System.Text.StringBuilder();
                foreach (var m in msgs) {
                    var content = m["content"];
                    if (content == null) { continue; }
                    if (content.Type == JTokenType.String) { sb.Append((string)content); sb.Append('\n'); }
                    else if (content.Type == JTokenType.Array) {
                        foreach (var part in (JArray)content) {
                            var t = part["text"];
                            if (t != null && t.Type == JTokenType.String) { sb.Append((string)t); sb.Append('\n'); }
                        }
                    }
                }
                return sb.ToString();
            } catch { return ""; }
        }" />
        <set-variable name="autoIsCoding" value="@{
            var text = (string)context.Variables["autoPromptText"];
            if (string.IsNullOrEmpty(text)) { return false; }
            var rx = new System.Text.RegularExpressions.Regex(@"```|=>|@@ |(^|\n)\s*(def |class |function |func |import |from |#include|public |private |protected |const |let |var |return |if \(|for \(|while \()|;\s*\n|\{\s*\n|\}\s*\n|Traceback|Exception|\.(py|ts|js|tsx|jsx|cs|java|go|rb|cpp|rs|sql|sh|ps1|ya?ml|html|css)\b", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            return rx.IsMatch(text);
        }" />
        <set-variable name="autoDecision" value="@{
            int len = ((string)context.Variables["autoPromptText"]).Length;
            bool coding = (bool)context.Variables["autoIsCoding"];
            int threshold = int.Parse("{{auto-route-length-threshold}}");
            int band = int.Parse("{{auto-route-ambiguous-band}}");
            if (coding) { return "full"; }
            if (len >= threshold + band) { return "full"; }
            if (len < threshold - band) { return "mini"; }
            return "ambiguous";
        }" />
        <choose>
          <when condition="@((string)context.Variables["autoDecision"] == "ambiguous" &amp;&amp; "{{auto-route-classifier-enabled}}".ToLowerInvariant() == "true")">
            <authentication-managed-identity resource="{{aoai-mi-audience}}" output-token-variable-name="autoClassifierToken" ignore-error="true" />
            <send-request mode="new" response-variable-name="autoClassifierResp" timeout="8" ignore-error="true">
              <set-url>@("{{aoai-private-base-url}}/openai/deployments/{{auto-route-classifier-deployment}}/chat/completions?api-version={{aoai-default-api-version}}")</set-url>
              <set-method>POST</set-method>
              <set-header name="Authorization" exists-action="override">
                <value>@("Bearer " + (string)context.Variables["autoClassifierToken"])</value>
              </set-header>
              <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
              </set-header>
              <set-body>@{
                  var prompt = (string)context.Variables["autoPromptText"];
                  if (prompt.Length > 4000) { prompt = prompt.Substring(0, 4000); }
                  var payload = new JObject(
                      new JProperty("messages", new JArray(
                          new JObject(new JProperty("role", "system"), new JProperty("content", "You are a routing classifier. Reply with exactly one lowercase word and nothing else: simple or complex. complex = coding, debugging, multi-step reasoning, or long/technical context; simple = short factual or conversational requests.")),
                          new JObject(new JProperty("role", "user"), new JProperty("content", prompt))
                      )),
                      new JProperty("max_tokens", 1),
                      new JProperty("temperature", 0)
                  );
                  return payload.ToString();
              }</set-body>
            </send-request>
            <set-variable name="autoClassifierLabel" value="@{
                try {
                    var resp = (IResponse)context.Variables["autoClassifierResp"];
                    if (resp == null || resp.StatusCode != 200) { return "error"; }
                    var j = resp.Body.As<JObject>();
                    var c = (string)(j["choices"]?[0]?["message"]?["content"]);
                    return (c ?? "").Trim().ToLowerInvariant();
                } catch { return "error"; }
            }" />
            <set-variable name="autoDecision" value="@(((string)context.Variables["autoClassifierLabel"]).StartsWith("simple") ? "mini" : "full")" />
          </when>
          <when condition="@((string)context.Variables["autoDecision"] == "ambiguous")">
            <set-variable name="autoDecision" value="full" />
          </when>
        </choose>
        <set-variable name="deploymentName" value="@((string)context.Variables["autoDecision"] == "mini" ? "{{auto-route-mini-deployment}}" : "{{auto-route-full-deployment}}")" />
      </when>
    </choose>

    <emit-metric name="copilot_byok_request" value="1" namespace="copilot.byok">
      <dimension name="developer_oid" value="@((string)context.Variables["developerOid"])" />
      <dimension name="developer_upn" value="@((string)context.Variables["developerUpn"])" />
      <dimension name="deployment_name" value="@((string)context.Variables["deploymentName"])" />
      <dimension name="auto_route" value="@((string)context.Variables["autoDecision"])" />
    </emit-metric>

    <!-- 5. Per-developer throttles (jwt mode keys on the Entra oid). Numbers come from named
         values so they are tunable per deployment without editing this policy:
           rate-limit-by-key        burst (calls/min)
           azure-openai-token-limit AI-cost guard (tokens/min, prompt+completion)
           quota-by-key             hard monthly call ceiling (30 days)
         (In subscriptionKey mode these live at PRODUCT scope instead; see apim-products.) -->
    <rate-limit-by-key calls="{{jwt-calls-per-minute}}" renewal-period="60"
                       counter-key="@((string)context.Variables["developerOid"])"
                       increment-condition="@(context.Response.StatusCode == 200)"
                       remaining-calls-header-name="x-byok-calls-remaining" />
    <azure-openai-token-limit tokens-per-minute="{{jwt-tokens-per-minute}}"
                              counter-key="@((string)context.Variables["developerOid"])"
                              estimate-prompt-tokens="true"
                              remaining-tokens-header-name="x-byok-tokens-remaining"
                              tokens-consumed-header-name="x-byok-tokens-consumed" />
    <quota-by-key calls="{{jwt-monthly-call-quota}}" renewal-period="2592000"
                  counter-key="@((string)context.Variables["developerOid"])" />

    <!-- 5b. Compatibility-only: ask the backend to include a `usage` object on the FINAL
         streamed chunk by injecting stream_options.include_usage=true into streaming JSON
         bodies. This is purely for parity with the GenAI/llm-* "wizard" convention so token
         usage is always AVAILABLE downstream. Our own telemetry does NOT depend on it: the
         inbound copilot_byok_request counter and the on-error copilot_byok_throttled metric
         both fire without `usage`, and the outbound token parser degrades to 0 cleanly when it
         is absent. Non-streaming or non-JSON bodies are forwarded unchanged. -->
    <set-body>@{
        try {
            var body = context.Request.Body?.As<JObject>(preserveContent: true);
            if (body == null) { return context.Request.Body?.As<string>(preserveContent: true); }
            var stream = body["stream"];
            if (stream != null && stream.Type == JTokenType.Boolean && (bool)stream) {
                var opts = body["stream_options"] as JObject;
                if (opts == null) { opts = new JObject(); body["stream_options"] = opts; }
                opts["include_usage"] = true;
                return body.ToString();
            }
            return context.Request.Body?.As<string>(preserveContent: true);
        } catch {
            return context.Request.Body?.As<string>(preserveContent: true);
        }
    }</set-body>

    <!-- 6. Strip the dev's credential before going to AOAI. -->
    <set-header name="api-key" exists-action="delete" />
    <set-header name="Authorization" exists-action="delete" />

    <!-- 7. Mint a managed identity token for AOAI and attach it. -->
    <authentication-managed-identity resource="{{aoai-mi-audience}}" />

    <!-- 8. Rewrite the OpenAI-style /openai/v1/<op> path to the Azure OpenAI
         deployment-scoped data-plane path the backend expects:
           /openai/v1/chat/completions  ->  /openai/deployments/{model}/chat/completions
         The {model} comes from the request body parsed above. -->
    <set-variable name="aoaiOp" value="@{
        var p = context.Request.OriginalUrl.Path.ToLowerInvariant();
        if (p.EndsWith("/chat/completions")) { return "chat/completions"; }
        if (p.EndsWith("/embeddings")) { return "embeddings"; }
        return "completions";
    }" />
    <rewrite-uri template="@("/openai/deployments/" + (string)context.Variables["deploymentName"] + "/" + (string)context.Variables["aoaiOp"])" copy-unmatched-params="true" />

    <!-- 9. Force a known-good api-version. Copilot CLI BYOK 'azure' mode omits or
         hardcodes it (see copilot-cli #3208); override guarantees a valid value. -->
    <set-query-parameter name="api-version" exists-action="override">
      <value>{{aoai-default-api-version}}</value>
    </set-query-parameter>

    <!-- 10. Route to the AOAI backend (a Url backend, or a multi-region Pool). The backend-id
         named value resolves to the single Url backend by default, or the pool when enabled. -->
    <set-backend-service backend-id="{{aoai-backend-id}}" />
  </inbound>

  <backend>
    <!-- In-request failover. A pooled backend's circuit breaker isolates a region ACROSS
         requests; this <retry> covers the SAME request: on a transient 429/5xx, re-run
         <forward-request>, which re-selects the next healthy pool member (honoring priority
         tiers / weights). No-op for a single Url backend, so it is safe in every deployment.
         buffer-request-body keeps the body available for the resend. -->
    <retry condition="@(context.Response != null && (context.Response.StatusCode == 429 || context.Response.StatusCode >= 500))" count="2" interval="0" first-fast-retry="true">
      <forward-request buffer-request-body="true" />
    </retry>
  </backend>

  <outbound>
    <base />

    <!-- Parse AOAI 'usage' object from response (if present and JSON) and emit token metrics. -->
    <choose>
      <when condition="@(context.Response.StatusCode == 200 && (context.Response.Headers.GetValueOrDefault("Content-Type","").StartsWith("application/json")))">
        <set-variable name="responseBody" value="@(context.Response.Body.As<JObject>(preserveContent: true))" />
        <emit-metric name="copilot_byok_prompt_tokens"     value="@((double)(int)(((JObject)context.Variables["responseBody"])?["usage"]?["prompt_tokens"] ?? 0))" namespace="copilot.byok">
          <dimension name="developer_oid"   value="@((string)context.Variables["developerOid"])" />
          <dimension name="developer_upn"   value="@((string)context.Variables["developerUpn"])" />
          <dimension name="deployment_name" value="@((string)context.Variables["deploymentName"])" />
        </emit-metric>
        <emit-metric name="copilot_byok_completion_tokens" value="@((double)(int)(((JObject)context.Variables["responseBody"])?["usage"]?["completion_tokens"] ?? 0))" namespace="copilot.byok">
          <dimension name="developer_oid"   value="@((string)context.Variables["developerOid"])" />
          <dimension name="developer_upn"   value="@((string)context.Variables["developerUpn"])" />
          <dimension name="deployment_name" value="@((string)context.Variables["deploymentName"])" />
        </emit-metric>
      </when>
    </choose>
  </outbound>

  <on-error>
    <base />

    <!-- jwt mode throttle attribution. The three throttles (rate-limit-by-key,
         azure-openai-token-limit, quota-by-key) return 429 by jumping here. Gateway logs carry
         no Entra oid, and the inbound copilot_byok_request metric already fired BEFORE the
         throttles ran, so a jwt-mode 429 is otherwise invisible per developer. Emit a dedicated
         throttle metric keyed on developerOid (set in inbound step 4, before the throttles) so
         jwt-mode limit hits are attributable — the jwt-mode analogue of the subscriptionKey
         gateway-log query in monitoring/kql/throttle-hits-per-developer.kql. Guarded on
         developerOid existing so pre-identity failures (e.g. invalid JWT) are skipped. -->
    <choose>
      <when condition="@(context.Response != null &amp;&amp; context.Response.StatusCode == 429 &amp;&amp; context.Variables.ContainsKey("developerOid"))">
        <emit-metric name="copilot_byok_throttled" value="1" namespace="copilot.byok">
          <dimension name="developer_oid"   value="@((string)context.Variables["developerOid"])" />
          <dimension name="developer_upn"   value="@(context.Variables.ContainsKey("developerUpn") ? (string)context.Variables["developerUpn"] : "unknown")" />
          <dimension name="deployment_name" value="@(context.Variables.ContainsKey("deploymentName") ? (string)context.Variables["deploymentName"] : "unknown")" />
          <dimension name="throttle"        value="@{
              var src = context.LastError?.Source ?? "";
              if (src.Contains("rate-limit-by-key")) { return "burst"; }
              if (src.Contains("azure-openai-token-limit")) { return "tokens"; }
              if (src.Contains("quota-by-key")) { return "quota"; }
              return "other";
          }" />
        </emit-metric>
      </when>
    </choose>
  </on-error>
</policies>
